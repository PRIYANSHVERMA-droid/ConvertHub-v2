{
  "name": "converthub-v2",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --win --x64"
  },
  "keywords": [],
  "author": "Priyansh Verma",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.converthub.v2",
    "productName": "ConvertHub v2",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "assets/**/*",
      "core/**/*",
      "ui/**/*",
      "main.js",
      "preload.js",
      "package.json",
      "!node_modules/.cache/**/*"
    ],
    "extraResources": [
      {
        "from": "engines",
        "to": "engines",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/app-icon.ico"
    }
  }
}
